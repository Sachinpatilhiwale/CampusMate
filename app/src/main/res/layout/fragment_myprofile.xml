<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Student_Fragment.MyprofileFragment">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Edit Icon -->
        <ImageView
            android:id="@+id/ivEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/edit"
            android:layout_gravity="end"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit Profile"/>

        <!-- Profile Photo -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivProfilePhoto"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/myprofile"
            android:scaleType="centerCrop"
            app:civ_border_width="2dp"
            app:civ_border_color="@color/teal_700"/>

        <!-- Select Profile Photo Button -->
        <Button
            android:id="@+id/btnSelectProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Change Photo"
            android:visibility="gone"
            android:backgroundTint="@color/teal_700"
            android:textColor="@android:color/white"/>

        <!-- Name Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <EditText
                android:id="@+id/etProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Name"
                android:paddingStart="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:enabled="false"/>
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="Role :"
                android:layout_gravity="center"
                android:textSize="19dp"
                android:paddingStart="16sp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:layout_marginTop="8dp"/>

        </com.google.android.material.card.MaterialCardView>


        <!-- Email Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Email"
                android:paddingStart="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:inputType="textEmailAddress"
                android:enabled="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Branch Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <EditText
                android:id="@+id/etSelectBranch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Select Branch"
                android:paddingStart="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:focusable="false"
                android:clickable="true"
                android:enabled="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Year Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <EditText
                android:id="@+id/etSelectYear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Select Year"
                android:paddingStart="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:focusable="false"
                android:clickable="true"
                android:enabled="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Gender Field -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:radius="12dp">

            <EditText
                android:id="@+id/etSelectGender"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Select Gender"
                android:paddingStart="16dp"
                android:textColor="@color/black"
                android:textColorHint="@color/black"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:focusable="false"
                android:clickable="true"
                android:enabled="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnProfileSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Save"
            android:visibility="gone"
            android:backgroundTint="@color/teal_700"
            android:textColor="@android:color/white"
            android:textStyle="bold"/>

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Logout"
            android:backgroundTint="@color/red_700"
            android:textColor="@android:color/white"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
